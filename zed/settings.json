{
    "theme": "Nord",
    "ui_font_size": 16,
    "buffer_font_size": 14,
    "relative_line_numbers": true,
    "autosave": "on_focus_change",
    "features": {
        "edit_prediction_provider": "none"
    },
    "assistant": {
        "enabled": false,
        "version": "2"
    },
    "languages": {
        "TypeScript": {
            "formatter": "prettier"
        },
        "JavaScript": {
            "formatter": "prettier"
        }
    }
}
